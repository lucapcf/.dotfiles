#!/bin/bash
:'
# Function to update the wallpaper
update_wallpaper() {
    while true; do
        for image in /home/lucapcf/Wallpapers/*; do
            feh --no-fehbg --bg-scale "$image"
            # Wait for 30 seconds before changing to the next wallpaper
            sleep 30
        done
    done
}

update_wallpaper &
'

feh --no-fehbg --bg-scale /home/lucapcf/Wallpapers/Cole_Thomas_The_Course_of_Empire_The_Arcadian_or_Pastoral_State_1836.jpg
